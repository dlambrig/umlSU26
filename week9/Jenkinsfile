// Week 9 capstone — build an image, push it to the local registry, then
// announce it on Kafka.
//
// The registry (localhost:5001) is plain HTTP with no auth, so the push needs
// NO certificates and NO `docker login` — Docker treats localhost registries as
// insecure by default. That's the simpler version of the earlier TLS + htpasswd
// setup.
//
// The pipeline runs on the Jenkins node (which has the docker CLI + the mounted
// Docker socket). The Kafka publish runs inside the kafka-python image, on the
// Kafka network, so it can reach the broker by name (week9-kafka:29092).
pipeline {
    agent any
    environment {
        REGISTRY = 'localhost:5001'
        IMAGE    = 'calculator'
        TAG      = "${BUILD_NUMBER}"
        TOPIC    = 'ci.images'
        BROKER   = 'week9-kafka:29092'
    }
    stages {
        stage('Build & push image') {
            steps {
                sh '''
                    docker build -t ${REGISTRY}/${IMAGE}:${TAG} week9/app
                    docker push ${REGISTRY}/${IMAGE}:${TAG}
                '''
            }
        }
        stage('Announce to Kafka') {
            steps {
                sh 'docker run --rm -i --network week9_default -e BROKER=${BROKER} -e TOPIC=${TOPIC} -e TAG=${TAG} -e BRANCH=${BRANCH_NAME:-main} localhost:5001/kafka-python:1 python - < week9/publish_event.py'
            }
        }
    }
}
