// Week 9 capstone (step 1) — the pipeline announces its build to Kafka.
// After a build, publish one ImagePushed event to the ci.images topic.
// Consuming/reacting to it comes in later weeks.
//
// The stage runs on a small image that already has the Kafka client
// (localhost:5001/kafka-python — built from the Dockerfile here and pushed to
// your local registry), joined to the Kafka network so it can reach the broker
// by name (week9-kafka:29092, the INTERNAL listener in docker-compose.yml).
pipeline {
    agent {
        docker {
            image 'localhost:5001/kafka-python:1'
            args '--network week9_default'
        }
    }
    environment {
        BROKER = 'week9-kafka:29092'
        TOPIC  = 'ci.images'
    }
    stages {
        stage('Build') {
            steps {
                echo 'build + push the image here, as in earlier weeks'
            }
        }
        stage('Announce to Kafka') {
            steps {
                sh '''python - <<'PY'
import json, os
from kafka import KafkaProducer

producer = KafkaProducer(
    bootstrap_servers=os.environ["BROKER"],
    value_serializer=lambda v: json.dumps(v).encode("utf-8"),
)
event = {
    "event": "ImagePushed",
    "image": "calculator",
    "tag": os.environ.get("BUILD_NUMBER", "0"),
    "branch": os.environ.get("BRANCH_NAME", "main"),
}
producer.send(os.environ["TOPIC"], event).get(timeout=10)
producer.flush()
print("announced to Kafka:", event)
PY'''
            }
        }
    }
}
